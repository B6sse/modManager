<Window x:Class="BassesModManager.CacheInstallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:Frosty.Controls;assembly=FrostyControls"
        Title="Installing cache..." Height="280" Width="550"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None" ResizeMode="NoResize"
        Background="Transparent" AllowsTransparency="True"
        Loaded="Window_Loaded">
    <Border Background="Black" BorderBrush="#8000FF" BorderThickness="2" CornerRadius="8">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="120"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="40"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>

            <Image x:Name="BannerImage" Grid.Row="0" Stretch="Uniform" Margin="0,0,0,10"/>

            <TextBlock Grid.Row="1" x:Name="StatusText" Text="Preparing..." Foreground="White" FontSize="14" Margin="0,0,0,10"/>

            <!-- Read phase: spinner. Write phase: progress bar -->
            <Grid Grid.Row="2" Margin="0,0,0,5">
                <StackPanel x:Name="SpinnerPanel" Orientation="Horizontal" HorizontalAlignment="Left" Visibility="Visible">
                    <ctrl:FrostySpinner Width="20" Height="20" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Loading data..." Foreground="#888" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <ProgressBar x:Name="ProgressBar" Minimum="0" Maximum="100" Value="0" Height="20"
                             Foreground="#8000FF" Background="#333" Visibility="Collapsed"/>
            </Grid>

            <TextBlock Grid.Row="3" Text="This may take a few seconds. Please wait..." 
                       Foreground="#888" FontSize="12" Margin="0,10,0,0"/>
        </Grid>
    </Border>
</Window>
