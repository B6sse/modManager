<Window x:Class="BassesModManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:BassesModManager.Converters"
        Title="Basse's Mod Manager" Height="500" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="Black"
        FontSize="15">
    <Grid Margin="20">
        <Grid.Resources>
            <converters:StringToImageSourceConverter x:Key="StringToImageSourceConverter"/>
            <!-- Purple button with hover sound -->
            <Style x:Key="PurpleButtonStyle" BasedOn="{StaticResource PurpleButtonStyleBase}" TargetType="Button">
                <EventSetter Event="MouseEnter" Handler="PlayHoverSound"/>
            </Style>
            <!-- RadioButton -->
            <Style TargetType="RadioButton" x:Key="WhiteDotRadioButton">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="Black"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <StackPanel Orientation="Horizontal">
                                <Grid Width="18" Height="18" Margin="0,0,8,0">
                                    <Ellipse Stroke="White" StrokeThickness="2" Fill="Black"/>
                                    <Ellipse x:Name="Dot" Width="10" Height="10" Fill="White" Visibility="Collapsed"/>
                                </Grid>
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Dot" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- Tooltip style -->
            <Style TargetType="ToolTip">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="#222"/>
                <Setter Property="FontSize" Value="15"/>
            </Style>
            <!-- CheckBox style for optional mods -->
            <Style TargetType="CheckBox" x:Key="PurpleCheckBoxStyle">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="box"
                                        Width="18" Height="18"
                                        Margin="0,0,6,0"
                                        CornerRadius="3"
                                        BorderThickness="2"
                                        BorderBrush="#8000FF"
                                        Background="Transparent">
                                    <Grid>
                                        <Path x:Name="check"
                                              Data="M2,9 L7,14 L16,3"
                                              Stroke="Black"
                                              StrokeThickness="2.0"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round"
                                              Stretch="None"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Visibility="Collapsed"/>
                                    </Grid>
                                </Border>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="box" Property="Background" Value="#8000FF"/>
                                    <Setter TargetName="check" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="box" Property="BorderBrush" Value="White"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="box" Property="BorderBrush" Value="#444"/>
                                    <Setter Property="Foreground" Value="#666"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <EventSetter Event="MouseEnter" Handler="PlayHoverSound"/>
                <EventSetter Event="Click" Handler="PlayClickSound"/>
            </Style>
            <!-- Mod card: image with hover border -->
            <Style TargetType="RadioButton" x:Key="ModCardStyle">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RadioButton">
                            <Border x:Name="border" CornerRadius="12" BorderThickness="4" BorderBrush="Transparent" Margin="0,0,20,8" Padding="0">
                                <Grid Width="100" Height="100">
                                    <Grid.Clip>
                                        <RectangleGeometry RadiusX="12" RadiusY="12" Rect="0,0,100,100"/>
                                    </Grid.Clip>
                                    <Image Source="{Binding ImagePath, Converter={StaticResource StringToImageSourceConverter}}"
                                           Width="100" Height="100" Stretch="Uniform"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#8000FF"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="#8000FF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
                <EventSetter Event="MouseEnter" Handler="PlayHoverSound"/>
                <EventSetter Event="PreviewMouseDown" Handler="PlayClickSound_Mouse"/>
            </Style>
        </Grid.Resources>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Back -->
            <RowDefinition Height="Auto"/>  <!-- 1: Heading -->
            <RowDefinition Height="Auto"/>  <!-- 2: Crosshair cards -->
            <RowDefinition Height="Auto"/>  <!-- 3: Additional mods -->
            <RowDefinition Height="*"/>     <!-- 4: Flexible spacer -->
            <RowDefinition Height="Auto"/>  <!-- 5: Launch button -->
            <RowDefinition Height="Auto"/>  <!-- 6: Version label -->
        </Grid.RowDefinitions>

        <!-- Back to game selection -->
        <Button Grid.Row="0" x:Name="BackToGameSelectionButton"
                Content="BACK"
                HorizontalAlignment="Left"
                Margin="0,0,0,20"
                Padding="10,4"
                Click="BackToGameSelectionButton_Click"
                Style="{StaticResource PurpleButtonStyle}"
                ToolTip="Return to game selection"/>

        <!-- Crosshair Selection Title -->
        <TextBlock Grid.Row="1"
                   Text="SELECT CROSSHAIR"
                   Style="{StaticResource HeadingTextStyle}"
                   Margin="0,0,0,10"/>
        <!-- Crosshair Selection: image cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
            <ItemsControl x:Name="ModListControl" HorizontalAlignment="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                            <RadioButton GroupName="ModsGroup"
                                         IsChecked="{Binding IsEnabled}"
                                         Style="{StaticResource ModCardStyle}"
                                         ToolTip="{Binding Name}"/>
                            <Grid Width="120" HorizontalAlignment="Left" Margin="0,4,0,0">
                                <TextBlock Text="{Binding Name}"
                                           Style="{StaticResource BodyTextStyle}"
                                           HorizontalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Additional mods section -->
        <StackPanel Grid.Row="3" Orientation="Vertical" Margin="0,20,0,0">
            <TextBlock Text="ADDITIONAL MODS"
                       Style="{StaticResource HeadingTextStyle}"
                       Margin="0,0,0,10"/>
            <StackPanel Orientation="Vertical">
                <CheckBox x:Name="ScoreboardCheckBox"
                          VerticalAlignment="Center"
                          Style="{StaticResource PurpleCheckBoxStyle}"
                          ToolTip="Enable improved scoreboard with the selected crosshair">
                    <TextBlock Text="Improved Scoreboard" Style="{StaticResource BodyTextStyle}"/>
                </CheckBox>
                <!-- Future optional mods can be added here -->
            </StackPanel>
        </StackPanel>

        <!-- Launch Button -->
        <Button Grid.Row="5"
                x:Name="LaunchGameButton"
                Content="LAUNCH GAME"
                Height="40"
                Margin="0,10,0,0"
                Click="LaunchGameButton_Click"
                Style="{StaticResource PurpleButtonStyle}"
                ToolTip="Select a mod before launching the game"/>

        <!-- Version label -->
        <TextBlock Grid.Row="6" Text="v1.2" FontSize="14" Foreground="White" FontWeight="Bold" VerticalAlignment="Bottom" HorizontalAlignment="Left" Margin="0,10,0,0"/>
    </Grid>
</Window> 